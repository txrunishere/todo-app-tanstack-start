generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Todo {
  id          String   @id @default(uuid())
  name        String
  isCompleted Boolean
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
}
